{
  "info": {
    "name": "Inventory Management API",
    "description": "Suppliers, Purchase Orders, Inventory. Use Login first, then copy access_token to collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('token', res.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your-admin@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Suppliers",
      "item": [
        {
          "name": "Get all suppliers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/suppliers"
          }
        },
        {
          "name": "Create supplier",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Supplies\",\n  \"email\": \"contact@acme.com\",\n  \"phone\": \"+1-555-0100\",\n  \"address\": \"123 Main St, City\"\n}"
            },
            "url": "{{baseUrl}}/suppliers"
          }
        },
        {
          "name": "Get supplier by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/suppliers/{{supplierId}}"
          }
        },
        {
          "name": "Update supplier",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Supplies Ltd\",\n  \"phone\": \"+1-555-0199\"\n}"
            },
            "url": "{{baseUrl}}/suppliers/{{supplierId}}"
          }
        },
        {
          "name": "Delete supplier",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/suppliers/{{supplierId}}"
          }
        }
      ]
    },
    {
      "name": "Purchase Orders",
      "item": [
        {
          "name": "Get all purchase orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/purchase-orders"
          }
        },
        {
          "name": "Create purchase order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplierId\": \"paste-supplier-uuid-here\",\n  \"items\": [\n    {\n      \"productId\": \"paste-product-uuid-here\",\n      \"quantity\": 10,\n      \"unitPrice\": \"25.00\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/purchase-orders"
          }
        },
        {
          "name": "Get purchase order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/purchase-orders/{{poId}}"
          }
        },
        {
          "name": "Update PO (status / payment)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Pending\",\n  \"paymentStatus\": \"Unpaid\"\n}"
            },
            "url": "{{baseUrl}}/purchase-orders/{{poId}}"
          }
        },
        {
          "name": "Receive order (add to inventory)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/purchase-orders/{{poId}}/receive"
          }
        },
        {
          "name": "Delete purchase order",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/purchase-orders/{{poId}}"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Get all inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/inventory"
          }
        },
        {
          "name": "Get inventory by product ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/inventory/by-product/{{productId}}"
          }
        },
        {
          "name": "Adjust inventory quantity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 100\n}"
            },
            "url": "{{baseUrl}}/inventory/adjust?productId={{productId}}"
          }
        }
      ]
    }
  ]
}
